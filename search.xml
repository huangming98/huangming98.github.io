    <content><![CDATA[<h3 id="运筹优化"><a href="#运筹优化" class="headerlink" title="运筹优化"></a><p align="center"><font face="黑体" size="5" color="black">运筹优化</font></p></h3><h5 id="车间调度领域"><a href="#车间调度领域" class="headerlink" title="车间调度领域"></a>车间调度领域</h5><ul>
